# Canonical site URL (SEO, sitemap, robots.txt)
PUBLIC_SITE_URL=https://example.com

# Local dev server port (Astro respects PORT)
PORT=4321

# Optional extra Vite allowedHosts in dev (comma-separated), e.g. ngrok
# DEV_ALLOWED_HOSTS=abc123.ngrok-free.app

# Contentful — https://app.contentful.com → Settings → API keys
# Set to true when the CMS integration should run at build time.
CONTENTFUL_ENABLED=false
CONTENTFUL_SPACE_ID=
CONTENTFUL_DELIVERY_TOKEN=
CONTENTFUL_PREVIEW_TOKEN=

# Floating music player playlist.
# Playlist JSON and MP3 files must be readable by the browser.
MUSIC_PLAYLIST_URL=https://s3.patrykb.pl/patrykbpl/audio/playlist.json
