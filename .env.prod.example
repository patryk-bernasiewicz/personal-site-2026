# Canonical site URL baked into Astro output.
PUBLIC_SITE_URL=https://example.com

# Host and container port. Mikrus default in this project: 3660.
HOST_BIND=127.0.0.1
PORT=3660

# Contentful is read at build time for static pages.
CONTENTFUL_ENABLED=false
CONTENTFUL_SPACE_ID=
CONTENTFUL_DELIVERY_TOKEN=
CONTENTFUL_PREVIEW_TOKEN=

MUSIC_PLAYLIST_URL=https://s3.patrykb.pl/patrykbpl/audio/playlist.json
