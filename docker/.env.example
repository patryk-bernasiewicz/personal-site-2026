# Canonical site URL (baked into build for sitemap / meta)
SITE_URL=https://example.com

# Host & container port (nginx listens on PORT inside the image)
PORT=3660

# Contentful (only when CONTENTFUL_ENABLED=true at build time)
CONTENTFUL_ENABLED=false
CONTENTFUL_SPACE_ID=
CONTENTFUL_DELIVERY_TOKEN=

# Optional: preview API for local dev (see root .env.example)
CONTENTFUL_PREVIEW_TOKEN=

# Floating music player.
MUSIC_PLAYLIST_URL=https://s3.patrykb.pl/patrykbpl/audio/playlist.json
