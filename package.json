{
  "name": "personal-site-2026",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:host": "astro dev --host 0.0.0.0",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "sync": "astro sync",
    "astro": "astro",
    "content:check": "tsx src/scripts/check-contentful.ts",
    "playwright:install": "playwright install chromium",
    "docker:up": "docker compose -f docker/compose.yaml --env-file docker/.env up -d --build",
    "docker:down": "docker compose -f docker/compose.yaml --env-file docker/.env down",
    "tunnel": "cloudflared tunnel --url http://localhost:4321"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@contentful/rich-text-html-renderer": "^17.2.2",
    "@contentful/rich-text-types": "^17.2.7",
    "@tailwindcss/vite": "^4.3.0",
    "@tsparticles/basic": "^4.1.3",
    "@tsparticles/engine": "^4.1.3",
    "astro": "^6.4.3",
    "clsx": "^2.1.1",
    "contentful": "^11.12.4",
    "embla-carousel": "^8.6.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^5.0.7",
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "playwright": "^1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
