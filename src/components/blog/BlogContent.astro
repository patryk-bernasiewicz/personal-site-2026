---
import Prose from '@/components/ui/Prose.astro';
import type { BlogPost } from '@/lib/contentful/types';
import { renderRichTextToHtml } from '@/lib/contentful/rich-text-renderer';

interface Props {
	post: BlogPost;
}

const { post } = Astro.props;
const html = await renderRichTextToHtml(post.content);
---

{
	post.coverImage && (
		<figure class="mb-8">
			<img
				src={post.coverImage.src}
				alt={post.coverImage.alt}
				class="aspect-[16/9] w-full rounded-card object-cover"
				loading="eager"
			/>
			{post.coverImage.caption && (
				<figcaption class="mt-3 overflow-wrap-anywhere text-caption leading-relaxed text-text-faint">
					{post.coverImage.caption}
				</figcaption>
			)}
		</figure>
	)
}

<Prose>
	<article set:html={html} />
</Prose>
