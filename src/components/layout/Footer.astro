---
import { siteConfig } from '@/config/site';
import { socialLinks } from '@/config/social';

interface Props {
	locale: import('@/lib/i18n/locales').Locale;
}

const { locale: _locale } = Astro.props;
void _locale;
---

<footer class="mt-auto border-t border-white/10">
	<div
		class="page-shell flex flex-col gap-4 py-8 text-sm text-text-muted sm:flex-row sm:items-center sm:justify-between"
	>
		<p>© {new Date().getFullYear()} {siteConfig.author.name}</p>
		<ul class="flex flex-wrap gap-4">
			{
				socialLinks.map((link) => (
					<li>
						<a
							href={link.href}
							class="text-caption font-semibold uppercase tracking-widest transition-colors hover:text-text-main"
							rel="noopener noreferrer"
						>
							{link.label}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</footer>
