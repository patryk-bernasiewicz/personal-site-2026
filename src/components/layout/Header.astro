---
import SiteLogo from '@/components/layout/SiteLogo.astro';
import { getDictionary } from '@/lib/i18n/dictionaries';
import { applyPolishTypography } from '@/lib/typography';
import type { Locale } from '@/lib/i18n/locales';
import type { RouteKey, StaticRouteKey } from '@/lib/i18n/routes';
import { getLocalizedRoute } from '@/lib/i18n/urls';

interface Props {
	locale: Locale;
	routeKey: RouteKey | 'blogPost';
	alternatePaths?: Partial<Record<Locale, string>>;
}

const { locale, routeKey, alternatePaths } = Astro.props;

const dictionary = getDictionary(locale);
const currentPath = Astro.url.pathname;

const navItems: Array<{ routeKey: StaticRouteKey; label: string }> = [
	{ routeKey: 'home', label: dictionary.nav.home },
	{ routeKey: 'resume', label: dictionary.nav.resume },
	{ routeKey: 'about', label: dictionary.nav.about },
	{ routeKey: 'blogIndex', label: dictionary.nav.blog },
];

const aria =
	locale === 'pl'
		? applyPolishTypography({
				mainNav: 'Główne',
				openMenu: 'Otwórz menu',
				closeMenu: 'Zamknij menu',
				mobileMenu: 'Menu nawigacji',
				themeToggle: 'Przełącz motyw (wkrótce)',
				langPlaceholder: 'Przełącznik języka (wkrótce)',
			})
		: {
				mainNav: 'Main',
				openMenu: 'Open menu',
				closeMenu: 'Close menu',
				mobileMenu: 'Navigation menu',
				themeToggle: 'Toggle theme (coming soon)',
				langPlaceholder: 'Language switcher (coming soon)',
			};

function isNavActive(href: string): boolean {
	return currentPath === href || currentPath.startsWith(`${href}/`);
}

function navLinkClass(isActive: boolean): string {
	return [
		'text-caption font-semibold uppercase tracking-widest transition-colors',
		isActive ? 'text-gold-soft' : 'text-text-muted hover:text-text-main',
	].join(' ');
}

// Reserved for future LanguageSwitcher (BaseLayout still passes these props).
void routeKey;
void alternatePaths;
---

<header
	id="site-header"
	class="site-header fixed top-0 z-50 w-full"
	data-scrolled="false"
>
	<div class="page-shell flex min-h-[var(--spacing-nav-h)] items-center justify-between gap-4 py-4">
		<a
			href={getLocalizedRoute('home', locale)}
			class="site-header__logo flex shrink-0 items-center gap-3 rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold-soft"
		>
			<SiteLogo class="h-10 w-10" />
			<span class="sr-only">{dictionary.nav.home}</span>
		</a>

		<div class="hidden items-center gap-8 lg:flex">
			<nav aria-label={aria.mainNav}>
				<ul class="flex items-center gap-6">
					{
						navItems.map((item) => {
							const href = getLocalizedRoute(item.routeKey, locale);
							return (
								<li>
									<a href={href} class={navLinkClass(isNavActive(href))}>
										{item.label}
									</a>
								</li>
							);
						})
					}
				</ul>
			</nav>

			<div class="flex items-center gap-4 border-l border-white/10 pl-4">
				<span
					class="text-caption font-semibold uppercase tracking-widest text-text-faint"
					aria-label={aria.langPlaceholder}
					title={aria.langPlaceholder}
				>
					{locale === 'pl' ? 'PL' : 'EN'}
				</span>
				<button type="button" class="site-header__theme-toggle" aria-label={aria.themeToggle}>
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5" />
						<path
							d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
						/>
					</svg>
				</button>
			</div>
		</div>

		<button
			type="button"
			id="mobile-nav-trigger"
			class="site-header__menu-btn flex h-11 w-11 items-center justify-center rounded-md border border-white/10 text-text-main transition-colors hover:border-white/20 hover:text-gold-soft lg:hidden"
			aria-expanded="false"
			aria-controls="mobile-nav-drawer"
			aria-label={aria.openMenu}
		>
			<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
				<path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
			</svg>
		</button>
	</div>
</header>

<div
	id="mobile-nav"
	class="site-mobile-nav"
	data-mobile-nav
	aria-hidden="true"
	inert
>
	<div class="site-mobile-nav__backdrop" data-mobile-backdrop></div>
	<aside
		id="mobile-nav-drawer"
		class="site-mobile-nav__drawer"
		role="dialog"
		aria-modal="true"
		aria-label={aria.mobileMenu}
		tabindex="-1"
	>
		<div class="site-mobile-nav__head">
			<a
				href={getLocalizedRoute('home', locale)}
				class="flex items-center gap-3"
				data-mobile-nav-link
			>
				<SiteLogo class="h-9 w-9" />
				<span class="sr-only">{dictionary.nav.home}</span>
			</a>
			<button
				type="button"
				class="site-mobile-nav__close flex h-11 w-11 items-center justify-center rounded-md border border-white/10 text-text-main transition-colors hover:border-white/20 hover:text-gold-soft"
				data-mobile-close
				aria-label={aria.closeMenu}
			>
				<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path
						d="M6 6l12 12M18 6L6 18"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"
					/>
				</svg>
			</button>
		</div>

		<nav class="site-mobile-nav__nav" aria-label={aria.mainNav}>
			<ul class="flex flex-col gap-1">
				{
					navItems.map((item) => {
						const href = getLocalizedRoute(item.routeKey, locale);
						return (
							<li>
								<a
									href={href}
									class:list={[
										'block rounded-md px-3 py-3 text-sm font-semibold uppercase tracking-widest transition-colors',
										isNavActive(href)
											? 'text-gold-soft'
											: 'text-text-muted hover:bg-white/5 hover:text-text-main',
									]}
									data-mobile-nav-link
								>
									{item.label}
								</a>
							</li>
						);
					})
				}
			</ul>
		</nav>

		<div
			class="site-mobile-nav__footer mt-auto flex items-center justify-between gap-4 border-t border-white/10 pt-6"
		>
			<span
				class="text-caption font-semibold uppercase tracking-widest text-text-faint"
				aria-label={aria.langPlaceholder}
				title={aria.langPlaceholder}
			>
				{locale === 'pl' ? 'PL / EN' : 'EN / PL'}
			</span>
			<button type="button" class="site-header__theme-toggle" aria-label={aria.themeToggle}>
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5" />
					<path
						d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"
					/>
				</svg>
			</button>
		</div>
	</aside>
</div>

<style is:global>
	.site-mobile-nav {
		position: fixed;
		inset: 0;
		z-index: 60;
		visibility: hidden;
		pointer-events: none;
		transition: visibility 0s linear 240ms;
	}

	.site-mobile-nav.is-open {
		visibility: visible;
		pointer-events: auto;
		transition-delay: 0s;
	}

	.site-mobile-nav__backdrop {
		position: absolute;
		inset: 0;
		background: rgba(5, 5, 5, 0.62);
		backdrop-filter: blur(4px);
		opacity: 0;
		transition: opacity 240ms ease;
		will-change: opacity;
	}

	.site-mobile-nav.is-open .site-mobile-nav__backdrop {
		opacity: 1;
	}

	.site-mobile-nav__drawer {
		position: absolute;
		top: 0;
		right: 0;
		display: flex;
		flex-direction: column;
		width: min(86vw, 360px);
		height: 100%;
		max-height: 100dvh;
		padding: 1.25rem 1.25rem 1.5rem;
		border-left: 1px solid rgba(255, 255, 255, 0.1);
		background: linear-gradient(180deg, rgba(16, 16, 16, 0.98), rgba(5, 5, 5, 0.98));
		box-shadow: -24px 0 80px rgba(0, 0, 0, 0.45);
		transform: translate3d(100%, 0, 0);
		transition: transform 240ms cubic-bezier(0.22, 1, 0.36, 1);
		will-change: transform;
		outline: none;
	}

	.site-mobile-nav.is-open .site-mobile-nav__drawer {
		transform: translate3d(0, 0, 0);
	}

	@media (prefers-reduced-motion: reduce) {
		.site-mobile-nav__backdrop {
			transition-duration: 0.01ms;
		}

		.site-mobile-nav__drawer {
			transition-duration: 0.01ms;
		}
	}
</style>

<style>
	.site-header {
		background: transparent;
		border-bottom: 1px solid transparent;
		backdrop-filter: blur(0);
		transition:
			background 220ms ease,
			backdrop-filter 220ms ease,
			border-color 220ms ease;
	}

	.site-header[data-scrolled='true'] {
		background: linear-gradient(to top, transparent, var(--color-ink));
		border-bottom-color: rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(24px);
	}

	.site-header__theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: var(--radius-button);
		color: var(--color-text-muted);
		transition:
			border-color 180ms ease,
			color 180ms ease;
	}

	.site-header__theme-toggle:hover {
		border-color: rgba(255, 255, 255, 0.2);
		color: var(--color-text-main);
	}

	.site-mobile-nav__head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 2rem;
	}

	.site-mobile-nav__nav {
		flex: 1;
	}
</style>

<script>
	type SiteHeaderState = {
		cleanup?: () => void;
		setupHandler?: () => void;
	};

	const FOCUSABLE_SELECTOR =
		'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])';

	const siteHeaderState = ((window as Window & { __siteHeaderState?: SiteHeaderState })
		.__siteHeaderState ??= {});

	function getFocusableElements(container: HTMLElement): HTMLElement[] {
		return Array.from(container.querySelectorAll<HTMLElement>(FOCUSABLE_SELECTOR)).filter(
			(element) =>
				!element.hasAttribute('disabled') &&
				element.tabIndex !== -1 &&
				(element.offsetParent !== null || element === document.activeElement),
		);
	}

	function setupSiteHeader() {
		siteHeaderState.cleanup?.();
		siteHeaderState.cleanup = undefined;

		const header = document.getElementById('site-header');
		const menuTrigger = document.getElementById('mobile-nav-trigger');
		const mobileNav = document.querySelector<HTMLElement>('[data-mobile-nav]');
		const drawer = document.getElementById('mobile-nav-drawer');
		const closeButton = document.querySelector<HTMLButtonElement>('[data-mobile-close]');
		const backdrop = document.querySelector<HTMLElement>('[data-mobile-backdrop]');
		const navLinks = document.querySelectorAll<HTMLAnchorElement>('[data-mobile-nav-link]');

		if (!header || !menuTrigger || !mobileNav || !drawer || !closeButton || !backdrop) {
			return;
		}

		const controller = new AbortController();
		const { signal } = controller;
		let restoreFocusTarget: HTMLElement | null = null;
		let openFrame: number | undefined;
		let focusTimer: number | undefined;

		const setScrolledState = () => {
			const scrolled = window.scrollY > 0;
			header.dataset.scrolled = scrolled ? 'true' : 'false';
		};

		const prefersReducedMotion = () =>
			window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		const isDrawerOpen = () => mobileNav.classList.contains('is-open');

		const cancelOpenFrame = () => {
			if (openFrame === undefined) {
				return;
			}

			window.cancelAnimationFrame(openFrame);
			openFrame = undefined;
		};

		const clearFocusTimer = () => {
			if (focusTimer === undefined) {
				return;
			}

			window.clearTimeout(focusTimer);
			focusTimer = undefined;
		};

		const trapFocus = (event: KeyboardEvent) => {
			if (event.key !== 'Tab' || !isDrawerOpen()) {
				return;
			}

			const focusable = getFocusableElements(drawer);
			if (focusable.length === 0) {
				return;
			}

			const first = focusable[0];
			const last = focusable[focusable.length - 1];
			const active = document.activeElement;

			if (event.shiftKey && active === first) {
				event.preventDefault();
				last.focus();
				return;
			}

			if (!event.shiftKey && active === last) {
				event.preventDefault();
				first.focus();
			}
		};

		const finishClose = () => {
			mobileNav.setAttribute('aria-hidden', 'true');
			mobileNav.setAttribute('inert', '');
		};

		const openDrawer = () => {
			if (isDrawerOpen()) {
				return;
			}

			restoreFocusTarget = menuTrigger;
			mobileNav.removeAttribute('inert');
			mobileNav.setAttribute('aria-hidden', 'false');
			mobileNav.classList.remove('is-open');
			void drawer.offsetWidth;
			cancelOpenFrame();
			openFrame = window.requestAnimationFrame(() => {
				mobileNav.classList.add('is-open');
				openFrame = undefined;
			});
			menuTrigger.setAttribute('aria-expanded', 'true');
			document.body.style.overflow = 'hidden';
			const focusDelay = prefersReducedMotion() ? 0 : 260;
			clearFocusTimer();
			focusTimer = window.setTimeout(() => {
				closeButton.focus();
				focusTimer = undefined;
			}, focusDelay);
		};

		const closeDrawer = ({ restoreFocus = true } = {}) => {
			const wasOpen = isDrawerOpen();

			cancelOpenFrame();
			clearFocusTimer();
			mobileNav.classList.remove('is-open');
			menuTrigger.setAttribute('aria-expanded', 'false');
			document.body.style.overflow = '';

			if (wasOpen && restoreFocus) {
				(restoreFocusTarget ?? menuTrigger).focus();
			}

			restoreFocusTarget = null;
			finishClose();
		};

		setScrolledState();
		window.addEventListener('scroll', setScrolledState, { passive: true, signal });

		menuTrigger.addEventListener('click', () => {
			if (isDrawerOpen()) {
				closeDrawer();
			} else {
				openDrawer();
			}
		}, { signal });

		closeButton.addEventListener('click', () => closeDrawer(), { signal });
		backdrop.addEventListener('click', () => closeDrawer(), { signal });

		navLinks.forEach((link) => {
			link.addEventListener('click', () => {
				if (!isDrawerOpen()) {
					return;
				}
				closeDrawer();
			}, { signal });
		});

		document.addEventListener('keydown', trapFocus, { signal });
		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && isDrawerOpen()) {
				closeDrawer();
			}
		}, { signal });

		siteHeaderState.cleanup = () => {
			closeDrawer({ restoreFocus: false });
			controller.abort();
		};
	}

	if (siteHeaderState.setupHandler) {
		document.removeEventListener('astro:page-load', siteHeaderState.setupHandler);
	}

	siteHeaderState.setupHandler = setupSiteHeader;
	setupSiteHeader();
	document.addEventListener('astro:page-load', siteHeaderState.setupHandler);
</script>
