---
import { getDictionary } from '@/lib/i18n/dictionaries';
import type { Locale } from '@/lib/i18n/locales';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
---

<a
	href="#main-content"
	class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:rounded-button focus:border focus:border-gold focus:bg-ink-card focus:px-4 focus:py-2 focus:text-caption focus:font-bold focus:uppercase focus:tracking-widest focus:text-text-main focus:shadow-gold"
>
	{dictionary.skipLink}
</a>
