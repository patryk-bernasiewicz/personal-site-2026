---
import AboutSummarySection from '@/components/sections/about/AboutSummarySection.astro';
import AboutHero from '@/components/sections/about/AboutHero.astro';
import AvoidAndLinksSection from '@/components/sections/about/AvoidAndLinksSection.astro';
import CurrentFocusSection from '@/components/sections/about/CurrentFocusSection.astro';
import ValuesSection from '@/components/sections/about/ValuesSection.astro';
import WorkEnvironmentSection from '@/components/sections/about/WorkEnvironmentSection.astro';
import WorkProcessSection from '@/components/sections/about/WorkProcessSection.astro';
import PageLayout from '@/layouts/PageLayout.astro';
import { getDictionary } from '@/lib/i18n/dictionaries';
import type { Locale } from '@/lib/i18n/locales';
import { getAlternateRoutes, getLocalizedRoute } from '@/lib/i18n/urls';
import { buildPageMetadata } from '@/lib/seo';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);

const metadata = buildPageMetadata({
	title: dictionary.meta.about.title,
	description: dictionary.meta.about.description,
	locale,
	canonical: getLocalizedRoute('about', locale),
	alternatePaths: getAlternateRoutes('about'),
});
---

<PageLayout {metadata} routeKey="about">
	<AboutHero {locale} />
	<AboutSummarySection {locale} />
	<WorkProcessSection {locale} />
	<ValuesSection {locale} />
	<WorkEnvironmentSection {locale} />
	<CurrentFocusSection {locale} />
	<AvoidAndLinksSection {locale} />
</PageLayout>
