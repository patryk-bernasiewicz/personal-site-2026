---
import BlogCard from '@/components/blog/BlogCard.astro';
import Container from '@/components/ui/Container.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import PageLayout from '@/layouts/PageLayout.astro';
import { getAllBlogPosts } from '@/lib/contentful/queries';
import { getDictionary } from '@/lib/i18n/dictionaries';
import type { Locale } from '@/lib/i18n/locales';
import { getAlternateRoutes, getLocalizedRoute } from '@/lib/i18n/urls';
import { buildPageMetadata } from '@/lib/seo';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
const posts = await getAllBlogPosts(locale);

const metadata = buildPageMetadata({
	title: dictionary.meta.blogIndex.title,
	description: dictionary.meta.blogIndex.description,
	locale,
	canonical: getLocalizedRoute('blogIndex', locale),
	alternatePaths: getAlternateRoutes('blogIndex'),
});
---

<PageLayout {metadata} routeKey="blogIndex">
	<Container tag="section" class="section-gap pt-nav">
		<SectionHeading
			eyebrow={dictionary.blog.eyebrow}
			title={dictionary.meta.blogIndex.title}
			description={dictionary.meta.blogIndex.description}
		/>
		{
			posts.length > 0 ? (
				<ul class="grid gap-4">
					{posts.map((post) => (
						<li>
							<BlogCard post={post} />
						</li>
					))}
				</ul>
			) : (
				<p class="text-body text-text-muted">{dictionary.blog.empty}</p>
			)
		}
	</Container>
</PageLayout>
