---
import AboutCard from '@/components/sections/about/AboutCard.astro';
import AboutSectionHeader from '@/components/sections/about/AboutSectionHeader.astro';
import Container from '@/components/ui/Container.astro';
import { getAboutPageContent } from '@/config/about-content';
import type { Locale } from '@/lib/i18n/locales';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const { principles } = getAboutPageContent(locale);
---

<Container
	tag="section"
	class="page-content-shell py-12 lg:py-18"
	aria-labelledby="about-values-heading"
>
	<AboutSectionHeader id="about-values-heading" label={principles.label} class="mb-8" />
	<ul class="grid gap-4 md:grid-cols-2 lg:grid-cols-6">
		{
			principles.items.map((item, index) => {
				const featured = index < 3;

				return (
					<li class={featured ? 'lg:col-span-2' : 'lg:col-span-2'}>
						<AboutCard
							class:list={[
								'h-full p-6 lg:p-7',
								featured &&
									'border-[rgba(217,164,65,0.42)] bg-[linear-gradient(135deg,rgba(217,164,65,0.11),transparent_48%),linear-gradient(180deg,rgba(255,255,255,0.04),rgba(255,255,255,0.01)),rgba(8,8,8,0.82)]',
							]}
						>
							<div class="relative flex min-h-[11.5rem] flex-col">
								<span
									class:list={[
										'mb-5 h-px w-16 bg-[linear-gradient(90deg,rgba(217,164,65,0.68),transparent)]',
										!featured && 'opacity-55',
									]}
									aria-hidden="true"
								/>
								<h3 class="font-display text-xl font-semibold leading-tight text-text-main">
									{item.title}
								</h3>
								<p class="mt-4 text-[0.98rem] leading-7 text-text-muted">
									{item.description}
								</p>
							</div>
						</AboutCard>
					</li>
				);
			})
		}
	</ul>
</Container>
