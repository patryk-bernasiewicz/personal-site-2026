---
import AboutCard from '@/components/sections/about/AboutCard.astro';
import AboutSectionHeader from '@/components/sections/about/AboutSectionHeader.astro';
import Container from '@/components/ui/Container.astro';
import { getAboutPageContent } from '@/config/about-content';
import type { Locale } from '@/lib/i18n/locales';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const { collaboration, workBest } = getAboutPageContent(locale);
---

<Container
	tag="section"
	class="max-w-[1180px] py-12 lg:py-18"
	aria-labelledby="about-collaboration-heading"
>
	<AboutSectionHeader id="about-collaboration-heading" label={collaboration.label} class="mb-8" />
	<div class="grid gap-6 lg:grid-cols-[0.82fr_1.18fr] lg:gap-9">
		<div class="space-y-5">
			<p class="max-w-xl text-[clamp(1.35rem,2vw,1.75rem)] leading-snug text-text-soft">
				{collaboration.note}
			</p>
			<p class="inline-flex rounded-sm border border-[rgba(217,164,65,0.42)] bg-[rgba(217,164,65,0.07)] px-4 py-2 text-caption font-bold uppercase tracking-[0.16em] text-gold-soft">
				{collaboration.badge}
			</p>
		</div>

		<AboutCard class="p-0">
			<div class="relative overflow-hidden rounded-[0.5rem]">
				<ol class="grid list-none p-0 sm:grid-cols-2">
					{
						collaboration.items.map((item) => (
							<li class="min-h-[11.5rem] border-b border-white/10 p-6 last:border-b-0 sm:border-r sm:even:border-r-0 sm:[&:nth-last-child(-n+2)]:border-b-0 lg:p-7">
								<h4 class="font-display text-xl font-semibold text-text-main">
									{item.title}
								</h4>
								<p class="mt-3 text-[0.98rem] leading-7 text-text-muted">
									{item.description}
								</p>
							</li>
						))
					}
				</ol>
			</div>
		</AboutCard>
	</div>
</Container>

<Container
	tag="section"
	class="max-w-[1180px] py-12 lg:py-20"
	aria-labelledby="about-work-heading"
>
	<AboutSectionHeader id="about-work-heading" label={workBest.label} class="mb-8" />
	<div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:gap-12">
		<div>
			<p class="max-w-2xl text-[clamp(1.55rem,2.6vw,2.35rem)] font-semibold leading-tight text-text-main">
				{workBest.statement}
			</p>
			<p class="mt-6 max-w-xl border-l border-[rgba(217,164,65,0.42)] pl-5 text-[1.05rem] leading-8 text-gold-soft">
				{workBest.highlight}
			</p>
		</div>

		<div class="border-t border-white/10 pt-6 lg:border-t-0 lg:pt-0">
			<p class="max-w-2xl text-body leading-relaxed text-text-muted">{workBest.context}</p>
			<ul class="mt-7 grid gap-3 sm:grid-cols-2">
				{
					workBest.bullets.map((bullet) => (
						<li class="grid grid-cols-[auto_1fr] items-start gap-3 rounded-[0.45rem] border border-white/10 bg-white/[0.018] px-4 py-3 text-[0.95rem] leading-6 text-text-soft">
							<span
								class="mt-[0.45rem] size-1.5 rounded-full bg-gold shadow-[0_0_14px_rgba(217,164,65,0.48)]"
								aria-hidden="true"
							/>
							<span>{bullet}</span>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</Container>
