---
import { getRecentExperiencePreview } from '@/config/resume-content';
import { getDictionary } from '@/lib/i18n/dictionaries';
import type { Locale } from '@/lib/i18n/locales';
import { getLocalizedRoute } from '@/lib/i18n/urls';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
const experiencePreview = dictionary.home.experiencePreview;
const previewRoles = getRecentExperiencePreview(locale);
const resumeHref = getLocalizedRoute('resume', locale);
---

<section
	class="experience-preview home-section-gap relative isolate bg-ink lg:overflow-hidden"
	aria-labelledby="experience-preview-heading"
	data-home-scroll-section
>
	<div class="page-shell">
		<div class="relative">
			<aside
				class="experience-preview__rail absolute top-0 right-full z-10 mr-6 hidden flex-col items-center lg:flex xl:mr-10"
				aria-hidden="true"
			>
				<span class="font-display text-sm font-semibold tracking-widest text-gold">
					{experiencePreview.number}
				</span>
				<div class="relative mt-4 flex flex-col items-center">
					<span class="size-1 rounded-full bg-white/30"></span>
					<div class="experience-preview__rail-line mt-2 w-px bg-white/14"></div>
				</div>
			</aside>

			<div
				class="experience-preview__rail-mobile mb-6 flex items-center gap-3 lg:hidden"
				aria-hidden="true"
			>
				<span class="font-display text-sm font-semibold tracking-widest text-gold">
					{experiencePreview.number}
				</span>
				<span class="h-px w-10 bg-white/14"></span>
			</div>

			<p class="eyebrow" id="experience-preview-heading">{experiencePreview.eyebrow}</p>

			<h2 class="sr-only">{experiencePreview.heading}</h2>

			<div class="experience-preview__cta-row mt-5 flex justify-start lg:justify-end">
				<a
					class="experience-preview__resume-link inline-flex items-center gap-2 text-caption font-semibold uppercase tracking-widest text-gold transition-colors hover:text-gold-soft focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-gold"
					href={resumeHref}
				>
					{experiencePreview.cta}
					<svg
						class="size-4 shrink-0"
						width="16"
						height="16"
						viewBox="0 0 16 16"
						fill="none"
						aria-hidden="true"
					>
						<path
							d="M3 8h10M9 4l4 4-4 4"
							stroke="currentColor"
							stroke-width="1.25"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</a>
			</div>

			<ol class="experience-preview__list mt-8 list-none p-0 lg:mt-10">
				{
					previewRoles.map((role) => (
						<li class="experience-preview__item">
							<div class="experience-preview__marker" aria-hidden="true">
								<span class="experience-preview__dot" />
								<span class="experience-preview__stem" />
							</div>
							<article class="experience-preview__body min-w-0">
								<p class="text-caption text-text-muted">{role.period}</p>
								<h3 class="mt-2 font-display text-base font-semibold leading-snug text-text-main">
									{role.title}
								</h3>
								<p class="mt-1 text-caption font-semibold text-gold">{role.company}</p>
								<p class="experience-preview__summary mt-3 text-body leading-relaxed text-text-muted max-lg:hidden">
									{role.summary}
								</p>
							</article>
						</li>
					))
				}
			</ol>
		</div>
	</div>
</section>

<style>
	.experience-preview__rail-line {
		height: clamp(3.5rem, 8vh, 5.5rem);
	}

	.experience-preview__list {
		display: grid;
		gap: 0;
	}

	.experience-preview__item {
		display: grid;
		grid-template-columns: auto 1fr;
		column-gap: 1.25rem;
		padding-block: 1.125rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}

	.experience-preview__item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.experience-preview__item:first-child {
		padding-top: 0;
	}

	.experience-preview__marker {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		padding-top: 0.25rem;
	}

	.experience-preview__dot {
		width: 0.375rem;
		height: 0.375rem;
		flex-shrink: 0;
		border-radius: 999px;
		background: rgb(217, 164, 65);
		box-shadow: 0 0 12px rgba(217, 164, 65, 0.42);
	}

	.experience-preview__stem {
		margin-top: 0.5rem;
		width: 1px;
		flex: 1;
		min-height: 1.5rem;
		background: rgba(255, 255, 255, 0.14);
	}

	.experience-preview__item:last-child .experience-preview__stem {
		display: none;
	}

	@media (min-width: 1024px) {
		.experience-preview__cta-row {
			margin-top: 0;
			position: absolute;
			top: 0;
			right: 0;
		}

		.experience-preview__list {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: clamp(1.5rem, 3vw, 2.5rem);
			align-items: start;
		}

		.experience-preview__item {
			grid-template-columns: minmax(0, 1fr);
			column-gap: 0;
			align-content: start;
			padding: 0;
			border-bottom: none;
		}

		.experience-preview__marker {
			align-items: flex-start;
			padding-bottom: 0.25rem;
			padding-top: 0;
		}

		.experience-preview__item:not(:last-child) .experience-preview__marker::after {
			content: '';
			position: absolute;
			top: 0.1875rem;
			left: 0.75rem;
			width: calc(100% + clamp(1.5rem, 3vw, 2.5rem));
			border-top: 1px dashed rgba(217, 164, 65, 0.24);
			pointer-events: none;
		}

		.experience-preview__stem {
			margin-top: 0.75rem;
			flex: none;
			height: clamp(1.25rem, 2.5vh, 1.75rem);
		}

		.experience-preview__item:last-child .experience-preview__stem {
			display: block;
		}
	}
</style>
