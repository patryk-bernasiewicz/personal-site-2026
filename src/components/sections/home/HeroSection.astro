---
import HeroCosmos from '@/components/sections/home/HeroCosmos.astro';
import HeroSilhouette from '@/components/sections/home/HeroSilhouette.astro';
import HeroParticleStream from '@/components/sections/home/HeroParticleStream.astro';
import { heroMediaFrameClass } from '@/components/sections/home/hero-media-frame';
import Button from '@/components/ui/Button.astro';
import { siteConfig } from '@/config/site';
import { socialIconPaths, socialLinks } from '@/config/social';
import { getDictionary } from '@/lib/i18n/dictionaries';
import type { Locale } from '@/lib/i18n/locales';
import { getLocalizedRoute } from '@/lib/i18n/urls';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
const hero = dictionary.home.hero;

const titleClass =
	locale === 'pl'
		? 'max-lg:text-[clamp(2.125rem,8.2vw,2.75rem)] max-lg:leading-[1.08] lg:text-[clamp(2.375rem,3.4vw,3.625rem)] lg:leading-[1.06] lg:max-w-[9.5em]'
		: 'max-lg:text-[clamp(2.25rem,8.5vw,2.875rem)] max-lg:leading-[1.04] lg:text-[clamp(2.625rem,4.1vw,4.5rem)] lg:leading-[1.02] lg:tracking-[-0.045em]';

const leadClass =
	locale === 'pl'
		? 'max-lg:text-[1.0625rem] max-lg:leading-[1.65] lg:max-w-md'
		: 'max-lg:text-[1.0625rem] max-lg:leading-[1.65] lg:max-w-lg';
---

<section
	class="hero-section relative isolate h-[min(82vh,100svh)] max-h-[min(82vh,100svh)] overflow-hidden bg-ink pt-nav max-lg:h-auto max-lg:max-h-none max-lg:min-h-[calc(100svh-0.5rem)]"
	aria-labelledby="hero-heading"
	data-home-scroll-section
>
	<HeroCosmos />

	<div class:list={['hero-overlay', heroMediaFrameClass, 'z-[1]']} aria-hidden="true"></div>

	<div class="hero-particle-layer" aria-hidden="true">
		<HeroParticleStream />
	</div>

	<HeroSilhouette />

	<div
		class="absolute right-[clamp(1rem,2.5vw,2rem)] bottom-[clamp(1.25rem,2.5vw,2rem)] z-10 hidden flex-col items-center gap-2.5 text-text-faint lg:flex"
		aria-hidden="true"
	>
		<span class="vertical-label text-caption uppercase">{hero.scroll}</span>
		<svg
			class="hero-scroll-arrow size-4"
			width="16"
			height="16"
			viewBox="0 0 16 16"
			fill="none"
			xmlns="http://www.w3.org/2000/svg"
			aria-hidden="true"
		>
			<path
				d="M8 3v10M4 9l4 4 4-4"
				stroke="currentColor"
				stroke-width="1.25"
				stroke-linecap="round"
				stroke-linejoin="round"></path>
		</svg>
	</div>

	<div
		class="page-shell relative z-10 flex h-full min-h-0 items-center py-[clamp(2rem,5vw,3.25rem)] max-lg:min-h-[calc(100svh-var(--spacing-nav-h)-0.5rem)] max-lg:items-end max-lg:pb-[clamp(2.5rem,8vw,3.75rem)]"
	>
		<div class="grid w-full grid-cols-1 lg:grid-cols-12">
			<div class="relative max-w-xl lg:col-span-5 lg:max-w-none">
				<aside
					class="hero-side-rail absolute top-0 right-full z-10 mr-6 hidden flex-col items-center lg:flex xl:mr-10"
					aria-label={hero.followMe}
				>
					<span class="font-display text-sm font-semibold tracking-widest text-gold">{hero.number}</span>
					<div class="relative mt-4 flex flex-col items-center" aria-hidden="true">
						<span class="size-1 rounded-full bg-white/30"></span>
						<div class="mt-2 h-12 w-px bg-white/14"></div>
					</div>
					<span class="vertical-label mt-5 text-caption text-text-faint">{hero.followMe}</span>
					<div
						class="mt-5 h-14 w-px bg-[linear-gradient(to_bottom,transparent,rgba(217,164,65,0.45),transparent)]"
						aria-hidden="true"
					>
					</div>
					<ul class="m-0 mt-5 flex list-none flex-col items-center gap-4 p-0">
						{
							socialLinks.map((link) => (
								<li>
									<a
										href={link.href}
										target={link.icon === 'email' ? undefined : '_blank'}
										rel={link.icon === 'email' ? undefined : 'noopener noreferrer'}
										aria-label={link.label}
										class="inline-flex size-8 items-center justify-center rounded-xs opacity-72 transition-[opacity,transform] duration-200 hover:-translate-y-0.5 hover:opacity-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-gold motion-reduce:hover:translate-y-0"
									>
										<img
											src={socialIconPaths[link.icon]}
											alt=""
											width="18"
											height="18"
											class="size-[1.125rem] object-contain"
											aria-hidden="true"
											loading="lazy"
											decoding="async"
										/>
									</a>
								</li>
							))
						}
					</ul>
				</aside>

				<div class="relative z-10">
					<p class="eyebrow max-lg:text-[0.6875rem]">{hero.eyebrow}</p>

					<h1
						id="hero-heading"
						class:list={[
							'mt-4 font-display text-section-title font-semibold text-balance text-text-main lg:mt-5',
							titleClass,
						]}
					>
						<span class="block">{hero.heading.line1}</span>
						<span class="block">{hero.heading.line2}</span>
						<span class="block text-gradient-gold">{hero.heading.line3}</span>
					</h1>

					<p class:list={['mt-4 max-w-lg text-body-large text-text-muted lg:mt-5', leadClass]}>
						{hero.lead}
					</p>
				</div>

				<div class="relative z-10 mt-6 flex flex-wrap items-center gap-x-6 gap-y-4 lg:mt-8 lg:gap-x-7 lg:gap-y-5">
					<Button href={getLocalizedRoute('resume', locale)} class="group max-lg:min-h-11">
						{hero.viewWork}
						<svg
							class="size-4 shrink-0 transition-transform duration-200 group-hover:translate-x-0.5 motion-reduce:transition-none motion-reduce:group-hover:translate-x-0"
							width="16"
							height="16"
							viewBox="0 0 16 16"
							fill="none"
							aria-hidden="true"
						>
							<path
								d="M3 8h10M9 4l4 4-4 4"
								stroke="currentColor"
								stroke-width="1.25"
								stroke-linecap="round"
								stroke-linejoin="round"></path>
						</svg>
					</Button>
					<a
						class="inline-flex items-center gap-3 rounded-xs text-caption font-semibold uppercase tracking-widest text-text-muted transition-colors hover:text-text-main focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-gold"
						href={`mailto:${siteConfig.author.email}`}
					>
						{hero.letsTalk}
						<span
							class="size-1.5 rounded-full bg-gold shadow-[0_0_10px_rgba(217,164,65,0.55)]"
							aria-hidden="true"></span>
					</a>
				</div>

				<ul
					class="hero-social-mobile relative z-10 m-0 mt-6 flex list-none items-center gap-4 p-0 lg:hidden"
					aria-label={hero.followMe}
				>
					{
						socialLinks.map((link) => (
							<li>
								<a
									href={link.href}
									target={link.icon === 'email' ? undefined : '_blank'}
									rel={link.icon === 'email' ? undefined : 'noopener noreferrer'}
									aria-label={link.label}
									class="inline-flex size-8 items-center justify-center opacity-72 transition-[opacity,transform] duration-200 hover:-translate-y-0.5 hover:opacity-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-gold motion-reduce:hover:translate-y-0"
								>
									<img
										src={socialIconPaths[link.icon]}
										alt=""
										width="18"
										height="18"
										class="size-[1.125rem] object-contain"
										aria-hidden="true"
										loading="lazy"
										decoding="async"
									/>
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</div>
</section>

<style>
	.hero-overlay {
		background:
			linear-gradient(
				90deg,
				rgba(5, 5, 5, 0.94) 0%,
				rgba(5, 5, 5, 0.72) 34%,
				rgba(5, 5, 5, 0.28) 58%,
				transparent 78%
			),
			linear-gradient(180deg, transparent 52%, rgba(5, 5, 5, 0.82) 100%);
	}

	.hero-particle-layer {
		position: absolute;
		top: 0;
		right: 0;
		bottom: 0;
		left: 0;
		z-index: 2;
		pointer-events: none;
		overflow: hidden;
	}

	@media (max-width: 1023px) {
		.hero-overlay {
			background:
				linear-gradient(
					180deg,
					rgba(5, 5, 5, 0.5) 0%,
					rgba(5, 5, 5, 0.28) 24%,
					rgba(5, 5, 5, 0.82) 68%,
					rgba(5, 5, 5, 0.96) 100%
				),
				linear-gradient(90deg, rgba(5, 5, 5, 0.9) 0%, rgba(5, 5, 5, 0.4) 100%);
		}
	}

	.hero-scroll-arrow {
		animation: hero-scroll-bounce 2.4s ease-in-out infinite;
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-scroll-arrow {
			animation: none;
		}
	}

	@keyframes hero-scroll-bounce {
		0%,
		100% {
			transform: translateY(0);
			opacity: 0.65;
		}

		50% {
			transform: translateY(4px);
			opacity: 1;
		}
	}
</style>
