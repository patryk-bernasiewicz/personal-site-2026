---
import { getDictionary } from '@/lib/i18n/dictionaries';
import type { Locale } from '@/lib/i18n/locales';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
const proofStrip = dictionary.home.proofStrip;
---

<section class="proof-strip bg-ink" aria-label={proofStrip.label}>
	<div class="page-shell">
		<ul class="proof-strip__list m-0 grid list-none p-0">
			{
				proofStrip.items.map((item) => (
					<li class="proof-strip__item">
						<strong class="font-display text-gold">{item.value}</strong>
						<span>{item.label}</span>
					</li>
				))
			}
		</ul>
	</div>
</section>

<style>
	.proof-strip {
		border-block: 1px solid rgba(217, 164, 65, 0.2);
	}

	.proof-strip__list {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.proof-strip__item {
		display: grid;
		align-content: center;
		gap: 0.35rem;
		min-height: clamp(6.25rem, 8vw, 7.25rem);
		min-width: 0;
		padding: clamp(1.25rem, 2.5vw, 1.75rem) clamp(1rem, 2.5vw, 1.5rem);
		border-left: 1px solid rgba(255, 255, 255, 0.1);
	}

	.proof-strip__item:last-child {
		border-right: 1px solid rgba(255, 255, 255, 0.1);
	}

	.proof-strip__item strong {
		font-size: clamp(1.6rem, 3vw, 2.25rem);
		font-weight: 650;
		line-height: 1;
		letter-spacing: 0;
	}

	.proof-strip__item span {
		max-width: 16rem;
		color: var(--color-text-muted);
		font-size: 0.9rem;
		line-height: 1.45;
	}

	@media (max-width: 900px) {
		.proof-strip__list {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.proof-strip__item:nth-child(odd) {
			border-left: 1px solid rgba(255, 255, 255, 0.1);
		}

		.proof-strip__item:nth-child(even) {
			border-right: 1px solid rgba(255, 255, 255, 0.1);
		}
	}

	@media (max-width: 520px) {
		.proof-strip__list {
			grid-template-columns: 1fr;
		}

		.proof-strip__item,
		.proof-strip__item:last-child {
			border-inline: 1px solid rgba(255, 255, 255, 0.1);
		}

		.proof-strip__item + .proof-strip__item {
			border-top: 1px solid rgba(255, 255, 255, 0.08);
		}
	}
</style>
