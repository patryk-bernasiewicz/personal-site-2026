					<stop offset="100%" stop-color="rgba(217,164,65,0)" />
				</linearGradient>
				<linearGradient id="ts-wave-near-gradient" x1="0" y1="36" x2="960" y2="36">
					<stop offset="0%" stop-color="rgba(217,164,65,0)" />
					<stop offset="7%" stop-color="rgba(217,164,65,0.28)" />
