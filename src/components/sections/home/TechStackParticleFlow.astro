		>
			<defs>
				<linearGradient id="ts-wave-far-gradient" x1="0" y1="30" x2="960" y2="30">
					<stop offset="0%" stop-color="rgba(217,164,65,0)" />
					<stop offset="8%" stop-color="rgba(217,164,65,0.22)" />
