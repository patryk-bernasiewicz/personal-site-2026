<div class="tech-stack-flow" data-tech-stack-flow aria-hidden="true">
	<div class="tech-stack-flow__mist" aria-hidden="true"></div>

	<div class="tech-stack-flow__waves">
		<svg
			class="tech-stack-flow__svg"
			viewBox="0 0 960 72"
			fill="none"
			preserveAspectRatio="xMidYMid slice"
