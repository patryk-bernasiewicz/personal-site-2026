---
import TechStackParticleFlow from '@/components/sections/home/TechStackParticleFlow.astro';
import { getDictionary } from '@/lib/i18n/dictionaries';
import type { Locale } from '@/lib/i18n/locales';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
const techStack = dictionary.home.techStack;

const technologies = [
	{ id: 'react', label: 'React', icon: 'react' },
	{ id: 'nextjs', label: 'Next.js', icon: 'nextjs' },
	{ id: 'typescript', label: 'TypeScript', icon: 'typescript' },
	{ id: 'ssr', label: 'SSR', icon: 'ssr' },
	{ id: 'rsc', label: 'React Server Components', icon: 'rsc' },
	{ id: 'tailwind', label: 'Tailwind CSS', icon: 'tailwind' },
	{ id: 'redux-toolkit', label: 'Redux Toolkit', icon: 'reduxToolkit' },
	{ id: 'react-query', label: 'React Query', icon: 'reactQuery' },
	{ id: 'storybook', label: 'Storybook', icon: 'storybook' },
	{ id: 'jest', label: 'Jest', icon: 'jest' },
	{ id: 'playwright', label: 'Playwright', icon: 'playwright' },
	{ id: 'turborepo', label: 'Turborepo', icon: 'turborepo' },
	{ id: 'microfrontends', label: 'Microfrontends', icon: 'microfrontends' },
	{ id: 'wcag', label: 'WCAG', icon: 'wcag' },
] as const;

type TechIcon = (typeof technologies)[number]['icon'];

const iconPaths: Record<Exclude<TechIcon, 'react'>, string[]> = {
	nextjs: [
		'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z',
		'M8.8 15.2V8.8l6.4 6.4V8.8',
		'M15.2 15.2 8.8 8.8',
	],
	typescript: [
		'M5 5h14v14H5V5z',
		'M8.3 9.2h6.2',
		'M11.4 9.2v6.4',
		'M15.7 15.2c.6.4 1.3.6 2 .2.5-.3.7-1.1-.1-1.5l-.9-.4c-.9-.4-1.2-1.3-.7-2 .5-.8 1.7-.9 2.7-.3',
	],
	ssr: [
		'M5 5.5h14v4.5H5V5.5z',
		'M5 14h14v4.5H5V14z',
		'M8 7.8h.1M8 16.3h.1M11 7.8h5M11 16.3h5',
	],
	rsc: [
		'M7 6.5 12 4l5 2.5v5L12 14l-5-2.5v-5z',
		'M7 12.5 12 15l5-2.5',
		'M7 16.5 12 19l5-2.5',
		'M12 9v5',
	],
	tailwind: [
		'M5 9.5c1.6-3.2 4.3-3.2 5.9 0 1.6-3.2 4.3-3.2 5.9 0',
		'M5 15c1.6-3.2 4.3-3.2 5.9 0 1.6-3.2 4.3-3.2 5.9 0',
	],
	reduxToolkit: [
		'M8.2 8.4a3.3 3.3 0 0 1 5.5-2.4c1.6 1.2 1.8 3.5.4 5',
		'M15.8 15.6a3.3 3.3 0 0 1-5.5 2.4c-1.6-1.2-1.8-3.5-.4-5',
		'M7.2 13.1a2 2 0 1 0 0-4 2 2 0 0 0 0 4z',
		'M16.8 14.9a2 2 0 1 0 0-4 2 2 0 0 0 0 4z',
		'M12 20a2 2 0 1 0 0-4 2 2 0 0 0 0 4z',
	],
	reactQuery: [
		'M7 7.5c1.2-1.4 2.9-2.2 5-2.2 3.1 0 5.5 1.8 6.4 4.4',
		'M17.8 7.3l.7 2.5-2.5.7',
		'M17 16.5c-1.2 1.4-2.9 2.2-5 2.2-3.1 0-5.5-1.8-6.4-4.4',
		'M6.2 16.7l-.7-2.5 2.5-.7',
		'M12 14.3a2.3 2.3 0 1 0 0-4.6 2.3 2.3 0 0 0 0 4.6z',
	],
	storybook: [
		'M7 4.5h10l1 15-6-2-6 2 1-15z',
		'M14.8 4.5v4l1.7-1',
		'M10 10.2c.6-.6 2.3-.7 3.2-.2 1 .6 1 1.9 0 2.5-.7.5-2.1.5-2.9.2',
	],
	jest: [
		'M9 4h6',
		'M11 4v5.8l-4.3 7.6A2 2 0 0 0 8.4 20h7.2a2 2 0 0 0 1.7-2.6L13 9.8V4',
		'M9.2 15h5.6',
	],
	playwright: [
		'M4.5 6h15v11.5h-15V6z',
		'M4.5 9.5h15',
		'M8.2 14.5l2 2 4.1-4.6',
	],
	turborepo: [
		'M5.5 5.5h5v5h-5v-5z',
		'M13.5 13.5h5v5h-5v-5z',
		'M13.5 5.5h5v5h-5v-5z',
		'M10.5 8h3M16 10.5v3M10.5 10.5l3 3',
	],
	microfrontends: [
		'M4.5 5h6v6h-6V5z',
		'M13.5 5h6v6h-6V5z',
		'M4.5 14h6v5h-6v-5z',
		'M13.5 14h6v5h-6v-5z',
		'M10.5 8h3M10.5 16.5h3',
	],
	wcag: [
		'M12 5.8a1.8 1.8 0 1 0 0-3.6 1.8 1.8 0 0 0 0 3.6z',
		'M5.2 8.2c4.5-1 9.1-1 13.6 0',
		'M12 8.8v5.1',
		'M8.7 20l2.1-6.1h2.4l2.1 6.1',
		'M8 11.5h8',
	],
};

function getIconPaths(icon: TechIcon): string[] {
	if (icon === 'react') {
		return [];
	}

	return iconPaths[icon];
}
---

<section
	class="tech-stack home-section-gap relative isolate overflow-hidden bg-ink"
	aria-label={techStack.label}
	data-home-scroll-section
>
	<TechStackParticleFlow />

	<div class="page-shell relative z-10">
		<div class="relative">
			<aside
				class="tech-stack__rail absolute top-0 right-full z-10 mr-6 hidden flex-col items-center lg:flex xl:mr-10"
				aria-hidden="true"
			>
				<span class="font-display text-sm font-semibold tracking-widest text-gold">
					{techStack.number}
				</span>
				<div class="relative mt-4 flex flex-col items-center">
					<span class="size-1 rounded-full bg-white/30"></span>
					<div class="tech-stack__rail-line mt-2 w-px bg-white/14"></div>
				</div>
			</aside>

			<div class="tech-stack__rail-mobile mb-6 flex items-center gap-3 lg:hidden" aria-hidden="true">
				<span class="font-display text-sm font-semibold tracking-widest text-gold">
					{techStack.number}
				</span>
				<span class="h-px w-10 bg-white/14"></span>
			</div>

			<div class="relative min-w-0 flex-1" data-tech-stack-carousel>
				<div class="flex items-center justify-between gap-6">
					<p class="eyebrow">{techStack.label}</p>

					<div class="tech-stack__controls flex items-center gap-2">
						<button
							class="tech-stack__control"
							type="button"
							aria-label={techStack.previous}
							data-tech-stack-prev
						>
							<svg
								class="size-4"
								viewBox="0 0 16 16"
								fill="none"
								stroke="currentColor"
								stroke-width="1.25"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<path d="M10 3.5 5.5 8 10 12.5"></path>
							</svg>
						</button>
						<button
							class="tech-stack__control"
							type="button"
							aria-label={techStack.next}
							data-tech-stack-next
						>
							<svg
								class="size-4"
								viewBox="0 0 16 16"
								fill="none"
								stroke="currentColor"
								stroke-width="1.25"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<path d="M6 3.5 10.5 8 6 12.5"></path>
							</svg>
						</button>
					</div>
				</div>

				<div class="tech-stack__viewport mt-7" data-tech-stack-viewport>
					<ul class="tech-stack__container m-0 flex list-none p-0">
						{
							technologies.map((tech) => (
								<li class="tech-stack__slide min-w-0">
									<figure class="tech-stack__item m-0 flex flex-col items-center text-center">
										<span class="tech-stack__icon mb-3 text-text-soft" aria-hidden="true">
											{
												tech.icon === 'react' ? (
													<svg
														class="size-8 sm:size-9"
														viewBox="0 0 24 24"
														fill="none"
														stroke="currentColor"
														stroke-width="1.2"
													>
														<ellipse cx="12" cy="12" rx="9.5" ry="3.6" />
														<ellipse cx="12" cy="12" rx="9.5" ry="3.6" transform="rotate(60 12 12)" />
														<ellipse cx="12" cy="12" rx="9.5" ry="3.6" transform="rotate(-60 12 12)" />
														<circle cx="12" cy="12" r="1.6" fill="currentColor" stroke="none" />
													</svg>
												) : (
													<svg
														class="size-8 sm:size-9"
														viewBox="0 0 24 24"
														fill="none"
														stroke="currentColor"
														stroke-width="1.35"
														stroke-linecap="round"
														stroke-linejoin="round"
													>
														{getIconPaths(tech.icon).map((iconPath) => (
															<path d={iconPath} />
														))}
													</svg>
												)
											}
										</span>
										<figcaption class="max-w-28 text-[0.6875rem] font-medium leading-snug tracking-wide text-text-muted sm:text-caption">
											{tech.label}
										</figcaption>
									</figure>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	import type { EmblaCarouselType } from 'embla-carousel';
	import EmblaCarousel from 'embla-carousel';

	const instances = new Map<HTMLElement, EmblaCarouselType>();

	function destroyCarousels(): void {
		for (const embla of instances.values()) {
			embla.destroy();
		}

		instances.clear();
	}

	function setupCarousels(): void {
		destroyCarousels();

		document.querySelectorAll<HTMLElement>('[data-tech-stack-carousel]').forEach((carousel) => {
			const viewport = carousel.querySelector<HTMLElement>('[data-tech-stack-viewport]');
			const prevButton = carousel.querySelector<HTMLButtonElement>('[data-tech-stack-prev]');
			const nextButton = carousel.querySelector<HTMLButtonElement>('[data-tech-stack-next]');

			if (!viewport || !prevButton || !nextButton) {
				return;
			}

			const embla = EmblaCarousel(viewport, {
				align: 'start',
				containScroll: 'trimSnaps',
				loop: true,
				slidesToScroll: 1,
			});

			prevButton.addEventListener('click', () => embla.scrollPrev(), false);
			nextButton.addEventListener('click', () => embla.scrollNext(), false);
			instances.set(carousel, embla);
		});
	}

	setupCarousels();
	document.addEventListener('astro:page-load', setupCarousels);
	document.addEventListener('astro:after-swap', destroyCarousels);
</script>

<style>
	.tech-stack__rail-line {
		height: clamp(3.5rem, 8vh, 5.5rem);
	}

	.tech-stack__viewport {
		--slide-gap: clamp(0.875rem, 1.8vw, 1.25rem);
		--visible-slides: 2;
		--slide-size: calc(
			(100% - (var(--slide-gap) * (var(--visible-slides) - 1))) / var(--visible-slides)
		);
		overflow: hidden;
		cursor: grab;
		user-select: none;
		-webkit-user-select: none;
		mask-image: linear-gradient(to right, transparent 0, #000 5%, #000 95%, transparent 100%);
		-webkit-mask-image: linear-gradient(
			to right,
			transparent 0,
			#000 5%,
			#000 95%,
			transparent 100%
		);
	}

	.tech-stack__viewport:active {
		cursor: grabbing;
	}

	.tech-stack__container {
		gap: var(--slide-gap);
		touch-action: pan-y pinch-zoom;
		user-select: none;
		-webkit-user-select: none;
	}

	.tech-stack__slide {
		flex: 0 0 var(--slide-size);
		user-select: none;
		-webkit-user-select: none;
	}

	.tech-stack__control {
		display: inline-flex;
		width: 2.25rem;
		height: 2.25rem;
		align-items: center;
		justify-content: center;
		border: 1px solid rgba(217, 164, 65, 0.34);
		border-radius: 999px;
		color: rgb(217, 164, 65);
		background: rgba(8, 8, 8, 0.42);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
		transition:
			border-color 180ms ease,
			background-color 180ms ease,
			color 180ms ease,
			transform 180ms ease;
	}

	.tech-stack__control:hover {
		border-color: rgba(241, 198, 106, 0.72);
		background: rgba(217, 164, 65, 0.1);
		color: rgb(241, 198, 106);
		transform: translateY(-1px);
	}

	.tech-stack__control:focus-visible {
		outline: 2px solid rgba(241, 198, 106, 0.9);
		outline-offset: 3px;
	}

	.tech-stack__icon svg {
		opacity: 0.82;
		filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.04));
		transition: opacity 220ms ease;
	}

	.tech-stack__item:hover .tech-stack__icon svg {
		opacity: 1;
	}

	@media (min-width: 640px) {
		.tech-stack__viewport {
			--visible-slides: 3;
		}
	}

	@media (min-width: 1024px) {
		.tech-stack__viewport {
			--visible-slides: 5;
		}
	}

	@media (min-width: 1280px) {
		.tech-stack__viewport {
			--visible-slides: 8;
			--slide-gap: clamp(1rem, 1.45vw, 1.5rem);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.tech-stack__control {
			transition: none;
		}

		.tech-stack__control:hover {
			transform: none;
		}
	}
</style>
