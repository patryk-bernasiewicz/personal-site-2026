---
import resumeBottomBackgroundJpg from '@/assets/images/resume-bottom-background.jpg';
import resumeBottomBackgroundWebp from '@/assets/images/resume-bottom-background.webp';
---

<div class="dcv-bottom-wave" aria-hidden="true">
	<picture>
		<source type="image/webp" srcset={resumeBottomBackgroundWebp.src} />
		<img
			src={resumeBottomBackgroundJpg.src}
			alt=""
			aria-hidden="true"
			width={resumeBottomBackgroundJpg.width}
			height={resumeBottomBackgroundJpg.height}
			loading="lazy"
			decoding="async"
		/>
	</picture>
</div>

<style>
	.dcv-bottom-wave {
		position: absolute;
		inset: 18% 0 0 0;
		height: min(36rem, 60vw);
		width: 100%;
		pointer-events: none;
		opacity: 0.42;
		mask-image: linear-gradient(180deg, transparent 0%, black 18%, black 80%, transparent);
	}

	.dcv-bottom-wave picture,
	.dcv-bottom-wave img {
		width: 100%;
		height: 100%;
	}

	.dcv-bottom-wave img {
		object-fit: cover;
		object-position: center bottom;
	}
</style>
