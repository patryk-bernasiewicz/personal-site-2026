---
import digitalResumeHero from '@/assets/images/digitalresume-hero.jpg';
import digitalResumeHeroWebp from '@/assets/images/digitalresume-hero.webp';
import type { Locale } from '@/lib/i18n/locales';
import Container from '@/components/ui/Container.astro';
import HeroMetric from './HeroMetric.astro';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;

const metricsPl = [
	{ value: 'Frontend produktowy', label: '9 lat doświadczenia przy realnych produktach' },
	{ value: 'CMS & content', label: 'Strony statyczne i z zarządzaną treścią' },
	{ value: 'Stabilność', label: 'Bugfixing, obsługa incidentów, utrzymanie' },
	{ value: 'Delivery', label: 'Testy, review, releasy' },
];

const metricsEn = [
	{ value: 'Product frontend', label: '9 years of experience with real products' },
	{ value: 'CMS & content', label: 'Static and content-managed websites' },
	{ value: 'Stability', label: 'Bugfixing, incidents, maintenance' },
	{ value: 'Delivery', label: 'Tests, reviews, releases' },
];

const metrics = locale === 'pl' ? metricsPl : metricsEn;
const heroCopy =
	locale === 'pl'
		? {
				eyebrow: 'CYFROWE PORTFOLIO',
				headingStart: 'Moja ścieżka',
				headingAccent: 'zawodowa.',
				lead: 'Ponad 9 lat praktyki w produktowych projektach webowych. Pracuję tam, gdzie frontend spotyka realne potrzeby produktu: architekturę, CMS, migracje, testy, dostępność i codzienne delivery.',
			}
		: {
				eyebrow: 'DIGITAL PORTFOLIO',
				headingStart: 'My professional',
				headingAccent: 'path.',
				lead: 'Over 9 years of product web delivery experience. I work where frontend meets real product needs: architecture, CMS, migrations, testing, accessibility, and daily shipping.',
			};
---

<section class="dcv-hero section-gap">
	<Container class="page-content-shell">
		<div class="dcv-hero__content">
			<div class="dcv-hero__copy">
				<p class="eyebrow">{heroCopy.eyebrow}</p>
				<h1>
					<span>{heroCopy.headingStart}</span>
					<strong>{heroCopy.headingAccent}</strong>
				</h1>
				<p class="dcv-hero__lead">{heroCopy.lead}</p>
			</div>

			<div class="dcv-hero__visual" aria-hidden="true">
				<picture class="dcv-hero__portrait">
					<source srcset={digitalResumeHeroWebp.src} type="image/webp" />
					<img
						src={digitalResumeHero.src}
						width={digitalResumeHero.width}
						height={digitalResumeHero.height}
						alt=""
						aria-hidden="true"
						loading="eager"
						fetchpriority="high"
						decoding="async"
					/>
				</picture>
			</div>

			<ul class="dcv-hero__metrics">
				{
					metrics.map((metric) => (
						<HeroMetric value={metric.value} label={metric.label} />
					))
				}
			</ul>
		</div>
	</Container>
</section>

<style>
	.dcv-hero {
		padding-top: 6.5rem;
		padding-bottom: 7rem;
	}

	.dcv-hero__content {
		margin: 0 auto;
		width: 100%;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(360px, 1fr);
		gap: 2rem 3.5rem;
		align-items: stretch;
	}

	.dcv-hero__copy {
		display: grid;
		grid-template-rows: auto auto auto;
		gap: 1.2rem;
		align-content: start;
	}

	.dcv-hero__copy h1 {
		margin: 0.4rem 0 0;
		color: var(--color-text-main);
		font-family: var(--font-display);
		font-size: clamp(3.7rem, 6.4vw, 6rem);
		line-height: 0.95;
		letter-spacing: 0;
	}

	.dcv-hero__copy h1 span,
	.dcv-hero__copy h1 strong {
		display: block;
	}

	.dcv-hero__copy h1 strong {
		color: var(--color-gold);
		font-weight: 500;
	}

	.dcv-hero__lead {
		margin: 0;
		max-width: 42rem;
		color: var(--color-text-muted);
		font-size: 1rem;
		line-height: 1.75;
	}

	.dcv-hero__metrics {
		grid-column: 1 / -1;
		justify-self: stretch;
		width: 100%;
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.9rem;
	}

	.dcv-hero__metrics li {
		position: relative;
		min-height: 7.15rem;
		border: 1px solid rgba(217, 164, 65, 0.24);
		border-radius: 0.58rem;
		padding: 1rem 0.9rem 0.95rem;
		background:
			linear-gradient(145deg, rgba(217, 164, 65, 0.105), transparent 52%),
			rgba(255, 255, 255, 0.018);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.035);
	}

	.dcv-hero__metrics li::before {
		content: "";
		position: absolute;
		top: -1px;
		left: 0.9rem;
		width: min(4.8rem, calc(100% - 1.8rem));
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
		box-shadow:
			0 0 10px rgba(217, 164, 65, 0.3),
			0 0 24px rgba(217, 164, 65, 0.14);
	}

	.dcv-hero__metrics li::after {
		content: "";
		position: absolute;
		top: -1rem;
		left: 0.35rem;
		width: min(5.9rem, calc(100% - 0.7rem));
		height: 1.65rem;
		background: radial-gradient(ellipse at center, rgba(217, 164, 65, 0.18), transparent 70%);
		filter: blur(0.55rem);
		pointer-events: none;
	}

	.dcv-hero-metric__value {
		margin: 0;
		color: var(--color-text-main);
		font-size: 1.15rem;
		font-weight: 600;
		line-height: 1.2;
	}

	.dcv-hero-metric__label {
		margin-top: 0.35rem;
		color: var(--color-text-muted);
		font-size: 0.8rem;
		line-height: 1.45;
	}

	.dcv-hero__visual {
		position: relative;
		min-height: 26.5rem;
		border: 1px solid rgba(217, 164, 65, 0.22);
		border-radius: 0.9rem;
		background: rgba(5, 5, 5, 0.4);
		overflow: hidden;
	}

	.dcv-hero__portrait {
		position: absolute;
		inset: 0;
		display: block;
	}

	.dcv-hero__portrait img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	@media (max-width: 1080px) {
		.dcv-hero {
			padding-top: 5.4rem;
			padding-bottom: 5.6rem;
		}

		.dcv-hero__content {
			grid-template-columns: 1fr;
		}

		.dcv-hero__metrics {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.dcv-hero__visual {
			min-height: 23rem;
		}
	}

	@media (max-width: 640px) {
		.dcv-hero__metrics {
			grid-template-columns: 1fr 1fr;
		}

		.dcv-hero__portrait img {
			object-position: 58% center;
		}

	}
</style>
