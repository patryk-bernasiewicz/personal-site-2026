const { locale } = Astro.props;
const current = data[locale];
---

<section class="dcv-experience section-gap" aria-label={current.title}>
	<Container class="page-content-shell">
		<p class="eyebrow">{current.title}</p>
		<p class="dcv-experience__intro">{current.intro}</p>

		<div class="dcv-experience__timeline" role="list">
			<div class="dcv-experience__rail" aria-hidden="true" />
			{
				current.items.map((item, index) => (
					<ExperienceTimelineItem
						item={item}
						locale={locale}
						tone={index < 3 ? 'featured' : index > 4 ? 'quiet' : 'regular'}
					/>
				))
			}
		</div>
	</Container>
</section>

<style>
	.dcv-experience {
		padding-block: 5.8rem;
	}

	.dcv-experience__intro {
		margin-top: 1rem;
		max-width: 58rem;
		color: var(--color-text-muted);
		font-size: 1rem;
		line-height: 1.72;
	}

	.dcv-experience__timeline {
		--timeline-rail-width: 9rem;
		--timeline-dot-size: 0.82rem;
		--timeline-dot-radius: 0.41rem;
		--timeline-dot-right: -0.54rem;
		--timeline-line-x: calc(
			var(--timeline-rail-width) - var(--timeline-dot-right) - var(--timeline-dot-radius)
		);
		margin-top: 2.4rem;
		position: relative;
	}

	.dcv-experience__rail {
		position: absolute;
		top: 0.75rem;
		bottom: 0.75rem;
		left: var(--timeline-line-x);
		width: 1px;
		transform: translateX(-50%);
		background: linear-gradient(180deg, rgba(217, 164, 65, 0.12), rgba(217, 164, 65, 0.7), rgba(217, 164, 65, 0.12));
	}

	@media (max-width: 980px) {
		.dcv-experience {
			padding-block: 5rem;
		}

		.dcv-experience__timeline {
			--timeline-item-padding-left: 1.1rem;
			--timeline-dot-left: -0.64rem;
			--timeline-line-x: calc(
				var(--timeline-item-padding-left) + var(--timeline-dot-left) + var(--timeline-dot-radius)
			);
		}
	}
</style>
