---
interface Props {
	value: string;
	label: string;
}

const { value, label } = Astro.props;
---

<li class="dcv-hero-metric">
	<p class="dcv-hero-metric__value">{value}</p>
	<p class="dcv-hero-metric__label">{label}</p>
</li>

<style>
	.dcv-hero-metric {
		position: relative;
		min-height: 7.15rem;
		border: 1px solid rgba(217, 164, 65, 0.24);
		border-radius: 0.58rem;
		padding: 1rem 0.9rem 0.95rem;
		background:
			linear-gradient(145deg, rgba(217, 164, 65, 0.105), transparent 52%),
			rgba(255, 255, 255, 0.018);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.035);
	}

	.dcv-hero-metric::before {
		content: "";
		position: absolute;
		top: -1px;
		left: 0.9rem;
		width: min(4.8rem, calc(100% - 1.8rem));
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
		box-shadow:
			0 0 10px rgba(217, 164, 65, 0.3),
			0 0 24px rgba(217, 164, 65, 0.14);
	}

	.dcv-hero-metric::after {
		content: "";
		position: absolute;
		top: -1rem;
		left: 0.35rem;
		width: min(5.9rem, calc(100% - 0.7rem));
		height: 1.65rem;
		background: radial-gradient(ellipse at center, rgba(217, 164, 65, 0.18), transparent 70%);
		filter: blur(0.55rem);
		pointer-events: none;
	}

	.dcv-hero-metric__value {
		margin: 0;
		color: var(--color-text-main);
		font-size: 1.15rem;
		font-weight: 650;
		line-height: 1.2;
	}

	.dcv-hero-metric__label {
		margin: 0.45rem 0 0;
		color: var(--color-text-muted);
		font-size: 0.82rem;
		line-height: 1.45;
	}
</style>
