---
import Container from '@/components/ui/Container.astro';
import { getLocalizedRoute } from '@/lib/i18n/urls';
import { getResumeCopy } from '@/config/resume-content';
import type { Locale } from '@/lib/i18n/locales';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const navigation = getResumeCopy(locale).navigationCards;
const aboutHref = getLocalizedRoute('about', locale);
const blogHref = getLocalizedRoute('blogIndex', locale);

const links = [
	{
		href: aboutHref,
		title: navigation.about.title,
		description: navigation.about.description,
		iconClass: 'resume-bottom-card__icon--0',
		external: false,
	},
	{
		href: blogHref,
		title: navigation.blog.title,
		description: navigation.blog.description,
		iconClass: 'resume-bottom-card__icon--2',
		external: false,
	},
];
---

<Container tag="section" class="page-content-shell relative z-10 pb-12 pt-4">
	<div class="grid gap-4 md:grid-cols-2">
		{
			links.map((link) => (
				<a
					href={link.href}
					target={link.external ? '_blank' : undefined}
					rel={link.external ? 'noopener noreferrer' : undefined}
					class="resume-bottom-card focus-visible:outline-none"
				>
					<span class={`resume-bottom-card__icon ${link.iconClass}`} aria-hidden="true"></span>
					<span>
						<strong>{link.title}</strong>
						<small>{link.description}</small>
					</span>
					<span class="resume-bottom-card__arrow" aria-hidden="true">→</span>
				</a>
			))
		}
	</div>
</Container>

<style>
	.resume-bottom-card {
		display: grid;
		grid-template-columns: 2rem 1fr auto;
		gap: 1.2rem;
		align-items: center;
		min-height: 6.6rem;
		border: 1px solid rgba(217, 164, 65, 0.48);
		border-radius: 0.35rem;
		background:
			linear-gradient(135deg, rgba(217, 164, 65, 0.1), transparent 46%),
			rgba(8, 8, 8, 0.78);
		padding: 1.25rem 1.35rem;
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.04),
			0 1.25rem 3rem rgba(0, 0, 0, 0.36);
		transition:
			border-color 180ms ease,
			transform 180ms ease,
			box-shadow 180ms ease;
	}

	.resume-bottom-card:hover {
		border-color: var(--color-gold);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.06),
			0 1.45rem 3.6rem rgba(0, 0, 0, 0.42),
			0 0 2rem rgba(217, 164, 65, 0.18);
		transform: translateY(-2px);
	}

	.resume-bottom-card strong,
	.resume-bottom-card small {
		display: block;
	}

	.resume-bottom-card strong {
		color: var(--color-text-main);
		font-size: 1.1rem;
		font-weight: 500;
	}

	.resume-bottom-card small {
		margin-top: 0.36rem;
		color: var(--color-text-muted);
		font-size: 0.82rem;
		line-height: 1.55;
	}

	.resume-bottom-card__icon {
		position: relative;
		width: 1.75rem;
		height: 1.75rem;
		color: var(--color-gold);
	}

	.resume-bottom-card__icon::before,
	.resume-bottom-card__icon::after {
		content: "";
		position: absolute;
		border: 1.5px solid currentColor;
	}

	.resume-bottom-card__icon--0::before {
		inset: 0.1rem 0.25rem;
		border-radius: 0.15rem;
	}

	.resume-bottom-card__icon--0::after {
		left: 0.58rem;
		top: 0.55rem;
		width: 0.65rem;
		height: 0.12rem;
		border-left: 0;
		border-right: 0;
	}

	.resume-bottom-card__icon--1::before {
		inset: 0.52rem 0.08rem 0.18rem;
		border-radius: 0.18rem;
	}

	.resume-bottom-card__icon--1::after {
		left: 0.2rem;
		top: 0.24rem;
		width: 0.72rem;
		height: 0.42rem;
		border-bottom: 0;
		border-radius: 0.18rem 0.18rem 0 0;
	}

	.resume-bottom-card__icon--2::before {
		inset: 0.12rem 0.55rem 0.1rem;
		border-radius: 999px;
		transform: rotate(42deg);
	}

	.resume-bottom-card__icon--2::after {
		right: 0.28rem;
		bottom: 0.1rem;
		width: 0.42rem;
		height: 0.42rem;
		border-top: 0;
		border-left: 0;
		transform: rotate(42deg);
	}

	.resume-bottom-card__arrow {
		color: var(--color-gold);
		font-size: 1.45rem;
	}
</style>
