---
import Container from '@/components/ui/Container.astro';
import { getResumeCopy } from '@/config/resume-content';
import type { Locale } from '@/lib/i18n/locales';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const projects = getResumeCopy(locale).projects;
---

<section class="dcv-projects section-gap" aria-labelledby="resume-projects-heading">
	<Container class="page-content-shell">
		<div class="dcv-projects__header">
			<div>
				<p class="eyebrow">{projects.label}</p>
				<h2 id="resume-projects-heading">{projects.title}</h2>
			</div>
			<p>{projects.intro}</p>
		</div>

		<div class="dcv-projects__grid" role="list">
			{
				projects.items.map((item, index) => (
					<article class="dcv-projects__card" role="listitem">
						<span>{String(index + 1).padStart(2, '0')}</span>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</article>
				))
			}
		</div>
	</Container>
</section>

<style>
	.dcv-projects {
		position: relative;
		padding-block: 5.5rem 5.75rem;
		overflow: hidden;
		background:
			radial-gradient(circle at 74% 8%, rgba(217, 164, 65, 0.12), transparent 30rem),
			linear-gradient(180deg, rgba(217, 164, 65, 0.035), transparent 58%);
	}

	.dcv-projects__header {
		display: grid;
		grid-template-columns: minmax(0, 0.92fr) minmax(0, 1fr);
		gap: 2rem;
		align-items: end;
	}

	.dcv-projects__header h2 {
		max-width: 44rem;
		margin: 1rem 0 0;
		color: var(--color-text-main);
		font-family: var(--font-display);
		font-size: clamp(2.15rem, 4vw, 3rem);
		font-weight: 500;
		line-height: 1.08;
		letter-spacing: 0;
	}

	.dcv-projects__header > p {
		max-width: 38rem;
		margin: 0;
		color: var(--color-text-muted);
		font-size: 1rem;
		line-height: 1.72;
	}

	.dcv-projects__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 2.2rem;
	}

	.dcv-projects__card {
		position: relative;
		min-height: 14rem;
		overflow: hidden;
		border: 1px solid rgba(217, 164, 65, 0.34);
		border-radius: 0.72rem;
		background:
			linear-gradient(145deg, rgba(217, 164, 65, 0.11), transparent 52%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.026), transparent),
			rgba(8, 8, 8, 0.82);
		padding: 1.45rem;
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.04),
			0 1.1rem 2.6rem rgba(0, 0, 0, 0.22);
	}

	.dcv-projects__card::after {
		content: "";
		position: absolute;
		inset: auto 1.1rem 0 1.1rem;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(217, 164, 65, 0.62), transparent);
		opacity: 0.42;
	}

	.dcv-projects__card span {
		color: var(--color-gold);
		font-size: 0.76rem;
		font-weight: 800;
		letter-spacing: 0.16em;
	}

	.dcv-projects__card h3 {
		margin: 1.1rem 0 0;
		color: var(--color-text-main);
		font-family: var(--font-display);
		font-size: 1.22rem;
		font-weight: 500;
		line-height: 1.22;
	}

	.dcv-projects__card p {
		margin: 0.86rem 0 0;
		color: var(--color-text-muted);
		font-size: 0.95rem;
		line-height: 1.66;
	}

	@media (max-width: 980px) {
		.dcv-projects__header,
		.dcv-projects__grid {
			grid-template-columns: 1fr;
		}

		.dcv-projects__header {
			align-items: start;
		}
	}

	@media (max-width: 640px) {
		.dcv-projects {
			padding-block: 4.75rem;
		}

		.dcv-projects__card {
			min-height: auto;
		}
	}
</style>
