---
import Container from '@/components/ui/Container.astro';
import Card from '@/components/ui/Card.astro';
import { getResumeCopy } from '@/config/resume-content';
import type { Locale } from '@/lib/i18n/locales';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const strengths = getResumeCopy(locale).strengths;
---

<Container tag="section" class="page-content-shell section-gap">
	<div class="flex items-center justify-between gap-4">
		<p class="eyebrow">{strengths.title}</p>
	</div>

	<div class="mt-8 grid gap-4 lg:grid-cols-2">
		{
			strengths.items.map((item) => (
				<Card class="h-full p-6 lg:p-7">
					<h3 class="font-display text-xl font-semibold leading-tight text-text-main">{item.title}</h3>
					<p class="mt-3 max-w-2xl text-body text-text-muted">{item.description}</p>
				</Card>
			))
		}
	</div>
</Container>
