---
import { getResumeCopy } from '@/config/resume-content';
import type { Locale } from '@/lib/i18n/locales';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const snapshot = getResumeCopy(locale).snapshot;
---

<section class="resume-summary">
	<div class="resume-summary__inner page-shell page-content-shell">
		<div class="resume-summary__heading">
			<p class="eyebrow">{snapshot.label}</p>
			<p>{snapshot.intro}</p>
		</div>

		<div class="resume-summary__grid">
			{
				snapshot.items.map((item, index) => (
					<article class="resume-summary__card">
						<span>{String(index + 1).padStart(2, '0')}</span>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.resume-summary {
		position: relative;
		z-index: 1;
		padding-block: clamp(4.75rem, 7vw, 6.75rem);
		background: transparent;
	}

	.resume-summary__heading {
		display: grid;
		grid-template-columns: minmax(0, 0.8fr) minmax(0, 1fr);
		gap: 2rem;
		align-items: end;
		margin-bottom: 1.8rem;
	}

	.resume-summary__heading p:last-child {
		max-width: 38rem;
		color: var(--color-text-muted);
		font-size: 1rem;
		line-height: 1.72;
	}

	.resume-summary__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1.05rem;
	}

	.resume-summary__card {
		position: relative;
		display: grid;
		grid-template-rows: auto auto 1fr;
		min-height: 14.25rem;
		overflow: hidden;
		border: 1px solid rgba(217, 164, 65, 0.34);
		border-radius: 0.72rem;
		background:
			linear-gradient(135deg, rgba(217, 164, 65, 0.12), transparent 44%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.025), transparent),
			rgba(10, 10, 10, 0.88);
		padding: 1.55rem;
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.04),
			0 1.1rem 2.6rem rgba(0, 0, 0, 0.24);
	}

	.resume-summary__card::after {
		content: "";
		position: absolute;
		inset: auto 1.1rem 0 1.1rem;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(217, 164, 65, 0.6), transparent);
		opacity: 0.45;
	}

	.resume-summary__card span {
		color: var(--color-gold);
		font-size: 0.76rem;
		font-weight: 800;
		letter-spacing: 0.16em;
	}

	.resume-summary__card h3 {
		margin-top: 1.15rem;
		color: var(--color-text-main);
		font-family: var(--font-display);
		font-size: 1.24rem;
		font-weight: 500;
		line-height: 1.22;
	}

	.resume-summary__card p {
		margin-top: 0.9rem;
		color: var(--color-text-muted);
		font-size: 0.96rem;
		line-height: 1.68;
	}

	@media (max-width: 1023px) {
		.resume-summary__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.resume-summary__heading,
		.resume-summary__grid {
			grid-template-columns: 1fr;
		}

		.resume-summary__card {
			min-height: auto;
		}
	}
</style>
