---
import Card from '@/components/ui/Card.astro';
import Container from '@/components/ui/Container.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { getSkillGroups } from '@/config/resume-content';
import { getDictionary } from '@/lib/i18n/dictionaries';
import type { Locale } from '@/lib/i18n/locales';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
const skillGroups = getSkillGroups(locale);
---

<Container tag="section" class="pb-8">
	<SectionHeading title={dictionary.resume.skillsTitle} />
	<ul class="grid gap-4 sm:grid-cols-3">
		{
			skillGroups.map((group) => (
				<li>
					<Card>
						<h3 class="font-medium text-text-main">{group.title}</h3>
						<ul class="mt-3 space-y-1 text-body text-text-muted">
							{group.items.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</Card>
				</li>
			))
		}
	</ul>
</Container>
