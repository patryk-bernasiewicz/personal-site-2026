---
interface Props {
	class?: string;
	tag?: 'div' | 'section' | 'main' | 'article';
	narrow?: boolean;
}

const { class: className = '', tag: Tag = 'div', narrow = false, ...rest } = Astro.props;
---

<Tag
	{...rest}
	class:list={[
		'page-shell',
		narrow && 'max-w-3xl',
		className,
	]}
>
	<slot />
</Tag>
