---
interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
	headingLevel?: 'h1' | 'h2';
}

const { eyebrow, title, description, headingLevel = 'h2' } = Astro.props;
const HeadingTag = headingLevel;
---

<div class="mb-8">
	{eyebrow && <p class="eyebrow">{eyebrow}</p>}
	<HeadingTag class="mt-2 font-display text-section-title text-text-main">{title}</HeadingTag>
	{description && <p class="mt-3 text-body-large text-text-muted">{description}</p>}
</div>
