---
interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mb-8">
	{eyebrow && <p class="eyebrow">{eyebrow}</p>}
	<h2 class="mt-2 font-display text-section-title text-text-main">{title}</h2>
	{description && <p class="mt-3 text-body-large text-text-muted">{description}</p>}
</div>
