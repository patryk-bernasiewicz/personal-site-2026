---
import Container from '@/components/ui/Container.astro';
import BlogContent from '@/components/blog/BlogContent.astro';
import BlogMeta from '@/components/blog/BlogMeta.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { BlogPost } from '@/lib/contentful/types';
import { buildPageMetadata } from '@/lib/seo';
import { getLocalizedBlogPostUrl } from '@/lib/i18n/urls';

interface Props {
	post: BlogPost;
	alternatePaths: Partial<Record<import('@/lib/i18n/locales').Locale, string>>;
}

const { post, alternatePaths } = Astro.props;

const metadata = buildPageMetadata({
	title: post.title,
	description: post.description,
	locale: post.locale,
	canonical: getLocalizedBlogPostUrl(post.slug, post.locale),
	ogImage: post.coverImage?.src,
	alternatePaths,
});
---

<BaseLayout {metadata} routeKey="blogPost">
	<Container tag="article" class="max-w-[52rem] section-gap pt-nav">
		<BlogMeta {post} />
		<h1 class="mt-4 font-display text-section-title text-balance text-text-main">{post.title}</h1>
		<p class="mt-4 text-body-large text-text-soft">{post.description}</p>
		<div class="mt-10">
			<BlogContent {post} />
		</div>
	</Container>
</BaseLayout>
