---
import Container from '@/components/ui/Container.astro';
import BlogContent from '@/components/blog/BlogContent.astro';
import BlogMeta from '@/components/blog/BlogMeta.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/config/site';
import type { BlogPost } from '@/lib/contentful/types';
import { buildBlogPostingJsonLd, buildPageMetadata } from '@/lib/seo';
import { getLocalizedBlogPostUrl } from '@/lib/i18n/urls';

interface Props {
	post: BlogPost;
	alternatePaths: Partial<Record<import('@/lib/i18n/locales').Locale, string>>;
}

const { post, alternatePaths } = Astro.props;
const canonical = post.canonicalUrl ?? getLocalizedBlogPostUrl(post.slug, post.locale);
const ogImage = post.ogImage ?? post.coverImage;

const metadata = buildPageMetadata({
	title: post.seoTitle,
	description: post.seoDescription,
	locale: post.locale,
	canonical,
	ogTitle: post.ogTitle,
	ogDescription: post.ogDescription,
	ogType: 'article',
	ogImage: ogImage?.src ?? siteConfig.defaultOgImage,
	ogImageAlt: ogImage?.alt ?? siteConfig.defaultOgImageAlt,
	noIndex: post.noIndex,
	alternatePaths,
	publishedTime: post.publishedAt,
	modifiedTime: post.updatedAt ?? post.publishedAt,
	tags: post.tags,
	section: post.category,
});

metadata.jsonLd = buildBlogPostingJsonLd(metadata);
---

<BaseLayout {metadata} routeKey="blogPost">
	<Container tag="article" class="max-w-[52rem] section-gap pt-nav">
		<BlogMeta {post} />
		<h1 class="mt-4 font-display text-section-title text-balance text-text-main">{post.seoTitle}</h1>
		<p class="mt-4 text-body-large text-text-soft">{post.seoDescription}</p>
		<div class="mt-10">
			<BlogContent {post} />
		</div>
	</Container>
</BaseLayout>
